# HomePiNAS Environment Configuration Template
# Rename this file to .env and fill in the values below.

# Database Connection (SQLite)
DATABASE_URL="file:./data/homepinas.db"

# Authentication
# Genera un secreto fuerte usando: openssl rand -base64 32
JWT_SECRET="YOUR_SUPER_SECRET_KEY_HERE"

# Server Configuration
PORT=3000
NODE_ENV="production"

# External Integrations (Optional)
# Telegram Bot for Alerts
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""

# Discord Webhook for Alerts
DISCORD_WEBHOOK_URL=""
