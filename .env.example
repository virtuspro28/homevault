# ═══════════════════════════════════════════════════════════════
# HomeVault Dashboard — Configuración de Entorno
# ═══════════════════════════════════════════════════════════════
# Duplica este archivo a .env y configura los valores según tu setup
# NUNCA confirmes .env al repositorio (incluido en .gitignore)

# ──────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ──────────────────────────────────────────────────────────────────
# Ruta de la base de datos SQLite (relativa o absoluta)
DATABASE_URL="file:./data/homevault.db"

# ──────────────────────────────────────────────────────────────────
# AUTENTICACIÓN & SEGURIDAD
# ──────────────────────────────────────────────────────────────────
# Clave secreta JWT para firmar tokens (genera una con: openssl rand -base64 32)
# CRÍTICO: Cambia este valor en producción. Si cambias aquí, todas las sesiones se invalidan
JWT_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# Duración de la sesión (formato: 7d, 24h, etc.) - Defecto: 7d
JWT_EXPIRES_IN="7d"

# ──────────────────────────────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────────────────────────────
# Puerto HTTP del servidor
PORT=3000

# Entorno de ejecución (development | production)
NODE_ENV="development"

# Nivel de logging (debug | info | warn | error)
LOG_LEVEL="info"

# CORS: Orígenes permitidos (separados por coma)
# En desarrollo: *
# En producción: especifica los orígenes reales
API_CORS_ORIGIN="*"

# ──────────────────────────────────────────────────────────────────
# ALMACENAMIENTO
# ──────────────────────────────────────────────────────────────────
# Ruta base para el almacenamiento (montajes, backups, appdata, etc.)
STORAGE_BASE_PATH="/mnt/storage"

# Ruta de backups (relativa a STORAGE_BASE_PATH)
BACKUP_PATH="backups"

# Ruta de datos de aplicaciones (relativa a STORAGE_BASE_PATH)
APP_DATA_PATH="appdata"

# ──────────────────────────────────────────────────────────────────
# DOCKER
# ──────────────────────────────────────────────────────────────────
# Socket de Docker (configuración estándar)
DOCKER_SOCKET="/var/run/docker.sock"

# PUID y PGID para contenedores (por defecto: 1000:1000)
PUID=1000
PGID=1000

# ──────────────────────────────────────────────────────────────────
# NOTIFICACIONES (OPCIONAL)
# ──────────────────────────────────────────────────────────────────
# Telegram Bot
TELEGRAM_ENABLED="false"
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""

# Discord Webhook
DISCORD_ENABLED="false"
DISCORD_WEBHOOK_URL=""

# Email Notifications
EMAIL_ENABLED="false"
EMAIL_FROM="noreply@homevault.local"
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASS=""

# ──────────────────────────────────────────────────────────────────
# MONITOREO & ALERTAS
# ──────────────────────────────────────────────────────────────────
# Umbral de temperatura (°C) para alertas
TEMP_THRESHOLD_WARNING=75
TEMP_THRESHOLD_CRITICAL=85

# Umbral de uso de almacenamiento (%) para alertas
STORAGE_THRESHOLD_WARNING=80
STORAGE_THRESHOLD_CRITICAL=95

# Habilitar telemetría anónima (ayuda a mejorar el proyecto)
TELEMETRY_ENABLED="true"

# ──────────────────────────────────────────────────────────────────
# SEGURIDAD AVANZADA
# ──────────────────────────────────────────────────────────────────
# Habilitar Fail2Ban integration
FAIL2BAN_ENABLED="true"

# Máximo de intentos de login fallidos antes de bloqueo temporal
MAX_LOGIN_ATTEMPTS=5

# Duración del bloqueo de IP (en minutos)
IP_LOCK_DURATION=30

# Habilitar verificación en dos pasos (si está implementado)
2FA_ENABLED="false"

# ──────────────────────────────────────────────────────────────────
# BACKUP & SNAPRAID (OPCIONAL)
# ──────────────────────────────────────────────────────────────────
# Habilitar integración con SnapRAID
SNAPRAID_ENABLED="false"
SNAPRAID_CONFIG_PATH="/etc/snapraid.conf"

# Habilitar backups automáticos
AUTO_BACKUP_ENABLED="true"

# Horario de backup automático (formato cron: 0 2 * * * = 2:00 AM)
AUTO_BACKUP_SCHEDULE="0 2 * * *"

# ──────────────────────────────────────────────────────────────────
# VPN (OPCIONAL - WireGuard)
# ──────────────────────────────────────────────────────────────────
VPN_ENABLED="false"
WIREGUARD_INTERFACE="wg0"
WIREGUARD_PORT=51820

# ──────────────────────────────────────────────────────────────────
# SERVICIOS EXTERNOS (OPCIONAL)
# ──────────────────────────────────────────────────────────────────
# Rclone para sincronización con cloud
RCLONE_ENABLED="false"
RCLONE_CONFIG_PATH="/home/pi/.config/rclone/rclone.conf"

# NextCloud / Synology / etc integration
CLOUD_SYNC_ENABLED="false"

# ──────────────────────────────────────────────────────────────────
# DEBUG (NO usar en producción)
# ──────────────────────────────────────────────────────────────────
# Modo debug (verbosidad máxima)
DEBUG="false"

# Mostrar queries SQL
DEBUG_SQL="false"

# Deshabilitar autenticación (SOLO para desarrollo)
SKIP_AUTH="false"
